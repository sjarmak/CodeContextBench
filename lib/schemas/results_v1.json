{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sourcegraph.com/schemas/eval-v2/results-v1.json",
  "title": "V2 Evaluation Results",
  "description": "Canonical results format for a single evaluation run",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "experiment_id",
    "invariants",
    "mcp_config",
    "timing",
    "summary_metrics"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for this results file"
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this run"
    },
    "experiment_id": {
      "type": "string",
      "description": "Parent experiment identifier"
    },
    "pair_id": {
      "type": ["string", "null"],
      "description": "Pair identifier if this run is part of a baseline/MCP pair"
    },
    "invariants": {
      "type": "object",
      "description": "Invariant properties that must match between paired runs",
      "required": ["invariant_hash", "benchmark", "model", "seed"],
      "properties": {
        "invariant_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA256 hash of all invariant properties"
        },
        "benchmark": {
          "type": "string",
          "description": "Benchmark name (e.g., 'swebenchpro')"
        },
        "benchmark_version": {
          "type": "string",
          "description": "Benchmark version"
        },
        "task_ids": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of task IDs included in this run"
        },
        "model": {
          "type": "string",
          "description": "Model identifier (e.g., 'anthropic/claude-opus-4-5')"
        },
        "seed": {
          "type": "integer",
          "description": "Random seed for reproducibility"
        },
        "agent": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "import_path": {"type": "string"},
            "version": {"type": "string"}
          }
        },
        "environment": {
          "type": "object",
          "properties": {
            "type": {"type": "string", "enum": ["docker", "local"]},
            "backend": {"type": "string"}
          }
        }
      }
    },
    "mcp_config": {
      "type": "object",
      "description": "MCP configuration for this run",
      "required": ["mcp_mode", "mcp_enabled"],
      "properties": {
        "mcp_mode": {
          "type": "string",
          "description": "MCP mode (baseline, deepsearch, deepsearch_hybrid, sourcegraph)"
        },
        "mcp_enabled": {
          "type": "boolean",
          "description": "Whether MCP was enabled for this run"
        },
        "mcp_servers": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of MCP server names configured"
        },
        "mcp_config_hash": {
          "type": ["string", "null"],
          "description": "SHA256 hash of MCP configuration (null if baseline)"
        }
      }
    },
    "timing": {
      "type": "object",
      "description": "Timing information for the run",
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when run started"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when run finished"
        },
        "duration_seconds": {
          "type": "number",
          "description": "Total duration in seconds"
        }
      }
    },
    "summary_metrics": {
      "type": "object",
      "description": "Aggregated metrics for the run",
      "properties": {
        "total_tasks": {
          "type": "integer",
          "description": "Total number of tasks in this run"
        },
        "resolved": {
          "type": "integer",
          "description": "Number of tasks resolved (reward = 1.0)"
        },
        "failed": {
          "type": "integer",
          "description": "Number of tasks that failed (reward = 0.0)"
        },
        "errored": {
          "type": "integer",
          "description": "Number of tasks that errored during execution"
        },
        "resolution_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of tasks resolved"
        },
        "mean_reward": {
          "type": "number",
          "description": "Mean reward across all tasks"
        }
      }
    },
    "per_task_metrics": {
      "type": "array",
      "description": "Per-task detailed metrics",
      "items": {
        "type": "object",
        "required": ["task_id"],
        "properties": {
          "task_id": {"type": "string"},
          "resolved": {"type": "boolean"},
          "reward": {"type": ["number", "null"]},
          "error": {"type": ["string", "null"]},
          "duration_seconds": {"type": ["number", "null"]},
          "agent_execution_seconds": {"type": ["number", "null"]},
          "verifier_seconds": {"type": ["number", "null"]}
        }
      }
    },
    "tool_usage": {
      "type": "object",
      "description": "Tool usage statistics",
      "properties": {
        "total_tool_calls": {"type": "integer"},
        "by_tool": {
          "type": "object",
          "additionalProperties": {"type": "integer"}
        },
        "mcp_tool_calls": {"type": "integer"},
        "local_tool_calls": {"type": "integer"}
      }
    },
    "harbor_artifacts": {
      "type": "object",
      "description": "Pointers to Harbor output artifacts",
      "properties": {
        "job_dir": {"type": ["string", "null"]},
        "trial_dirs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "result_json": {"type": ["string", "null"]},
        "trajectory_file": {"type": ["string", "null"]},
        "logs": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "error": {
      "type": ["object", "null"],
      "description": "Error information if the run failed",
      "properties": {
        "error_class": {"type": "string"},
        "error_message": {"type": "string"}
      }
    }
  }
}
