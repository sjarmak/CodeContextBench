{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sourcegraph.com/schemas/eval-v2/comparison-v1.json",
  "title": "V2 Pair Comparison",
  "description": "Comparison results for a baseline vs MCP pair",
  "type": "object",
  "required": [
    "schema_version",
    "pair_id",
    "experiment_id",
    "invariant_hash",
    "baseline_run",
    "mcp_run"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for this comparison file"
    },
    "pair_id": {
      "type": "string",
      "description": "Unique identifier for this pair"
    },
    "experiment_id": {
      "type": "string",
      "description": "Parent experiment identifier"
    },
    "invariant_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA256 hash of invariants shared between runs"
    },
    "invariants": {
      "type": "object",
      "description": "Invariant properties shared between paired runs",
      "properties": {
        "benchmark": {"type": "string"},
        "task_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "model": {"type": "string"},
        "seed": {"type": "integer"}
      }
    },
    "baseline_run": {
      "type": "object",
      "description": "Summary of the baseline run",
      "required": ["run_id", "mcp_mode"],
      "properties": {
        "run_id": {"type": "string"},
        "mcp_mode": {
          "type": "string",
          "const": "baseline"
        },
        "summary_metrics": {
          "type": "object",
          "properties": {
            "resolution_rate": {"type": "number"},
            "mean_reward": {"type": "number"}
          }
        }
      }
    },
    "mcp_run": {
      "type": "object",
      "description": "Summary of the MCP run",
      "required": ["run_id", "mcp_mode"],
      "properties": {
        "run_id": {"type": "string"},
        "mcp_mode": {"type": "string"},
        "summary_metrics": {
          "type": "object",
          "properties": {
            "resolution_rate": {"type": "number"},
            "mean_reward": {"type": "number"}
          }
        }
      }
    },
    "delta_summary": {
      "type": "object",
      "description": "Summary of differences between runs",
      "properties": {
        "resolution_rate_delta": {
          "type": "number",
          "description": "MCP rate - baseline rate"
        },
        "resolution_rate_improvement_pct": {
          "type": "number",
          "description": "Percentage improvement in resolution rate"
        },
        "mean_reward_delta": {
          "type": "number",
          "description": "MCP reward - baseline reward"
        },
        "mcp_tool_calls_total": {
          "type": "integer",
          "description": "Total MCP tool calls in MCP run"
        },
        "duration_delta_seconds": {
          "type": "number",
          "description": "MCP duration - baseline duration"
        }
      }
    },
    "per_task_deltas": {
      "type": "array",
      "description": "Per-task comparison deltas",
      "items": {
        "type": "object",
        "required": ["task_id", "outcome"],
        "properties": {
          "task_id": {"type": "string"},
          "baseline_resolved": {"type": "boolean"},
          "mcp_resolved": {"type": "boolean"},
          "baseline_reward": {"type": "number"},
          "mcp_reward": {"type": "number"},
          "reward_delta": {"type": "number"},
          "duration_delta_seconds": {"type": "number"},
          "mcp_tool_calls": {"type": "integer"},
          "outcome": {
            "type": "string",
            "enum": ["both_pass", "both_fail", "mcp_only_pass", "baseline_only_pass"]
          }
        }
      }
    },
    "outcome_breakdown": {
      "type": "object",
      "description": "Count of each outcome type",
      "properties": {
        "both_pass": {
          "type": "integer",
          "description": "Tasks passed by both baseline and MCP"
        },
        "both_fail": {
          "type": "integer",
          "description": "Tasks failed by both baseline and MCP"
        },
        "mcp_only_pass": {
          "type": "integer",
          "description": "Tasks passed only by MCP"
        },
        "baseline_only_pass": {
          "type": "integer",
          "description": "Tasks passed only by baseline"
        }
      }
    },
    "error": {
      "type": ["object", "null"],
      "description": "Error information if comparison failed",
      "properties": {
        "error_class": {"type": "string"},
        "error_message": {"type": "string"}
      }
    }
  }
}
