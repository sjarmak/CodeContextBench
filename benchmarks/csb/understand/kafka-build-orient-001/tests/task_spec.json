{
  "id": "kafka-build-orient-001",
  "artifacts": {
    "oracle": {
      "required_files": [
        {
          "repo": "",
          "path": "{'weight': 0.2, 'description': 'References kafka-server-start.sh as entry script', 'patterns': ['kafka-server-start\\\\.sh', 'bin/kafka-server-start']}"
        },
        {
          "repo": "",
          "path": "{'weight': 0.25, 'description': 'References KafkaServer or BrokerServer/KafkaRaftServer classes', 'patterns': ['(?i)kafkaserver', '(?i)brokerserver', '(?i)kafkaraftserver']}"
        },
        {
          "repo": "",
          "path": "{'weight': 0.2, 'description': 'References KafkaApis.scala or handleCreateTopicsRequest', 'patterns': ['KafkaApis', 'handleCreateTopics', 'kafka/server/KafkaApis']}"
        },
        {
          "repo": "",
          "path": "{'weight': 0.2, 'description': 'References KafkaConfig.scala file location', 'patterns': ['KafkaConfig\\\\.scala', 'core/src/main/scala/kafka/server/KafkaConfig']}"
        },
        {
          "repo": "",
          "path": "{'weight': 0.15, 'description': 'References DynamicBrokerConfig for runtime updates', 'patterns': ['DynamicBrokerConfig', '(?i)dynamic.*config']}"
        }
      ],
      "required_symbols": [],
      "required_references": [],
      "dependency_chains": [
        {
          "steps": [
            {
              "weight": 0.2,
              "description": "Explains that core/ contains broker implementation in Scala",
              "patterns": [
                "(?i)core",
                "(?i)broker",
                "(?i)scala"
              ]
            },
            {
              "weight": 0.35,
              "description": "Describes topic creation flow: AdminClient -> KafkaApis -> AdminManager",
              "patterns": [
                "(?i)adminclient|createtopics",
                "(?i)kafkaapis",
                "(?i)adminmanager|handlecreatetopics"
              ]
            },
            {
              "weight": 0.15,
              "description": "Explains configDef.define() pattern for config definition",
              "patterns": [
                "configDef\\.define",
                "(?i)define"
              ]
            },
            {
              "weight": 0.3,
              "description": "Describes steps to add broker config: modify KafkaConfig.scala, add field, extract value",
              "patterns": [
                "KafkaConfig",
                "(?i)field|add.*field",
                "(?i)value|extract|getString"
              ]
            }
          ]
        }
      ]
    }
  },
  "evaluation": {
    "checks": [
      {
        "type": "file_set_match",
        "params": {}
      },
      {
        "type": "dependency_chain",
        "params": {}
      },
      {
        "type": "keyword_presence",
        "params": {
          "required_keywords": [
            "Identifies Gradle as the build system",
            "Identifies core modules: core, clients, server/streams",
            "Identifies KafkaConfig as the configuration registry",
            "Mentions testing frameworks (EmbeddedKafka or TopologyTestDriver)"
          ]
        }
      }
    ]
  }
}
