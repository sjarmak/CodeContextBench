# CCX-agentic-082 — sg_only variant
# No local repo clone — agent uses Sourcegraph MCP exclusively for code access.
# The verifier clones mirror repos at verification time (no /repo_full/ backup).

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV SOURCEGRAPH_REPOS="sg-benchmarks/kubernetes-kubernetes,sg-benchmarks/kubernetes-client-go,sg-benchmarks/kubernetes-api,sg-benchmarks/etcd-io-etcd"

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ca-certificates \
    python3 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Empty workspace — agent discovers code via MCP tools only
RUN git init && \
    git config user.email "agent@example.com" && \
    git config user.name "Agent" && \
    git config --global safe.directory '*'

# Create log directories
RUN mkdir -p /logs/agent /logs/verifier

# Mark sg_only mode — verifiers and eval scripts check this flag
RUN touch /tmp/.sg_only_mode

RUN echo '{"workdir":"/workspace","repos":[{"mirror":"sg-benchmarks/kubernetes--v1.32.0","target_dir":"kubernetes"},{"mirror":"sg-benchmarks/client-go--v0.32.0","target_dir":"client-go"},{"mirror":"sg-benchmarks/api--v0.32.0","target_dir":"api"},{"mirror":"sg-benchmarks/etcd-io-etcd","target_dir":"etcd"}]}' > /tmp/.sg_only_clone_manifest.json

ENTRYPOINT []
