{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codecontextbench.dev/schemas/submission.schema.json",
  "title": "CodeScaleBench Submission",
  "description": "Public submission format for external teams submitting benchmark results to CodeScaleBench.",
  "type": "object",
  "required": ["suite", "agent_info", "results", "csb_score", "metadata"],
  "properties": {
    "suite": {
      "type": "string",
      "description": "Benchmark suite name, e.g. 'ccb_k8sdocs', 'ccb_locobench'."
    },
    "agent_info": {
      "type": "object",
      "description": "Information about the agent that produced these results.",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Agent name, e.g. 'claude-code', 'aider'."
        },
        "version": {
          "type": ["string", "null"],
          "description": "Agent version string."
        },
        "model_info": {
          "type": ["object", "null"],
          "description": "Primary model used by the agent.",
          "properties": {
            "name": {
              "type": "string",
              "description": "Model identifier, e.g. 'anthropic/claude-opus-4-5-20251101'."
            },
            "provider": {
              "type": ["string", "null"],
              "description": "Model provider name."
            }
          }
        }
      },
      "additionalProperties": true
    },
    "results": {
      "type": "array",
      "description": "Array of per-task results.",
      "items": {
        "type": "object",
        "required": ["task_name", "reward"],
        "properties": {
          "task_name": {
            "type": "string",
            "description": "Canonical task name, e.g. 'sgt-001'."
          },
          "reward": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Canonical reward value (0.0-1.0)."
          },
          "csb_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Per-task CodeScaleBench composite score (0-100)."
          },
          "failure_categories": {
            "type": "array",
            "description": "Observatory-derived failure classifications.",
            "items": {
              "type": "object",
              "required": ["category", "confidence", "evidence"],
              "properties": {
                "category": {
                  "type": "string",
                  "description": "Failure category label."
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Confidence score (0.0-1.0)."
                },
                "evidence": {
                  "type": "string",
                  "description": "Evidence supporting this classification."
                }
              },
              "additionalProperties": false
            }
          },
          "started_at": {
            "type": "string",
            "description": "ISO 8601 timestamp when the trial started."
          },
          "finished_at": {
            "type": "string",
            "description": "ISO 8601 timestamp when the trial finished."
          },
          "agent_result": {
            "type": ["object", "null"],
            "description": "Agent execution metrics (tokens, cost).",
            "properties": {
              "n_input_tokens": { "type": ["integer", "null"] },
              "n_output_tokens": { "type": ["integer", "null"] },
              "cost_usd": { "type": ["number", "null"] }
            }
          }
        },
        "additionalProperties": true
      }
    },
    "csb_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Aggregate CodeScaleBench composite score (0-100) across all tasks in this submission."
    },
    "metadata": {
      "type": "object",
      "description": "Submission metadata.",
      "required": ["timestamp", "csb_version"],
      "properties": {
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp of submission generation."
        },
        "csb_version": {
          "type": "string",
          "description": "CodeScaleBench version used to produce this submission, e.g. '1.0.0'."
        },
        "run_id": {
          "type": ["string", "null"],
          "description": "Optional run identifier for traceability."
        },
        "notes": {
          "type": ["string", "null"],
          "description": "Optional free-text notes about this submission."
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
