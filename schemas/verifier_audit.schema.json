{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Verifier Audit Results",
  "description": "Per-verifier false positive/negative rates with confidence intervals from the verifier audit framework.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "total_audited",
    "flagged_verifiers",
    "results"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version identifier",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the audit was generated"
    },
    "total_audited": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of verifiers audited"
    },
    "flagged_verifiers": {
      "type": "array",
      "description": "Task IDs of verifiers with >10% false negative rate",
      "items": {
        "type": "string"
      }
    },
    "results": {
      "type": "array",
      "description": "Per-verifier audit results",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "false_positive_rate",
          "false_negative_rate",
          "confidence_interval_95",
          "n_good_tested",
          "n_bad_tested",
          "pass_threshold"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Canonical task identifier"
          },
          "false_positive_rate": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Proportion of known-bad solutions incorrectly scored as passing"
          },
          "false_negative_rate": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Proportion of known-good solutions incorrectly scored as failing"
          },
          "confidence_interval_95": {
            "type": "object",
            "description": "95% Wilson score confidence intervals for FP and FN rates",
            "required": ["fp_lower", "fp_upper", "fn_lower", "fn_upper"],
            "properties": {
              "fp_lower": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "fp_upper": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "fn_lower": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "fn_upper": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              }
            },
            "additionalProperties": false
          },
          "n_good_tested": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of known-good solutions tested"
          },
          "n_bad_tested": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of known-bad solutions tested"
          },
          "pass_threshold": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Score threshold above which a solution is considered passing"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
