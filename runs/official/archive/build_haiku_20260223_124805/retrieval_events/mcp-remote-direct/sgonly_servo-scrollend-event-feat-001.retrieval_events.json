        "file_path": "/workspace/components/script/dom/document.rs",
        "old_string": "    /// <https://drafts.csswg.org/cssom-view/#document-run-the-scroll-steps>\n    pub(crate) fn run_the_scroll_steps(&self, can_gc: CanGc) {\n        // Step 1.\n        // > Run the steps to dispatch pending scrollsnapchanging events for doc.\n        // TODO(#7673): Implement scroll snapping\n\n        // Step 2\n        // > For each item target in doc's pending scroll event targets, in the order they\n        // > were added to the list, run these substeps:\n        // Step 3.\n        // > Empty doc's pending scroll event targets.\n        // Since the scroll event callback could trigger another scroll event, we are taking all of the\n        // current scroll event to avoid borrow checking error.\n        rooted_vec!(let notify_list <- self.pending_scroll_event_targets.take().into_iter());\n        for target in notify_list.iter() {\n            if target.downcast::<Document>().is_some() {\n                // Step 2.1\n                // > If target is a Document, fire an event named scroll that bubbles at target.\n                target.fire_bubbling_event(Atom::from(\"scroll\"), can_gc);\n            } else if target.downcast::<Element>().is_some() {\n                // Step 2.2\n                // > Otherwise, fire an event named scroll at target.\n                target.fire_event(Atom::from(\"scroll\"), can_gc);\n            }\n        }\n\n        // Step 4.\n        // > Run the steps to dispatch pending scrollsnapchange events for doc.\n        // TODO(#7673): Implement scroll snapping\n    }",
        "new_string": "    /// <https://drafts.csswg.org/cssom-view/#document-run-the-scroll-steps>\n    pub(crate) fn run_the_scroll_steps(&self, can_gc: CanGc) {\n        // Step 1.\n        // > Run the steps to dispatch pending scrollsnapchanging events for doc.\n        // TODO(#7673): Implement scroll snapping\n\n        // Step 2\n        // > For each item target in doc's pending scroll event targets, in the order they\n        // > were added to the list, run these substeps:\n        // Step 3.\n        // > Empty doc's pending scroll event targets.\n        // Since the scroll event callback could trigger another scroll event, we are taking all of the\n        // current scroll event to avoid borrow checking error.\n        rooted_vec!(let notify_list <- self.pending_scroll_event_targets.take().into_iter());\n        for target in notify_list.iter() {\n            if target.downcast::<Document>().is_some() {\n                // Step 2.1\n                // > If target is a Document, fire an event named scroll that bubbles at target.\n                target.fire_bubbling_event(Atom::from(\"scroll\"), can_gc);\n            } else if target.downcast::<Element>().is_some() {\n                // Step 2.2\n                // > Otherwise, fire an event named scroll at target.\n                target.fire_event(Atom::from(\"scroll\"), can_gc);\n            }\n        }\n\n        // Schedule scrollend events for any targets that received scroll events\n        // We need to do this after firing scroll events\n        if !notify_list.is_empty() {\n            // Move the scroll event targets to pending_scrollend_targets for debouncing\n            for target in notify_list.iter() {\n                self.pending_scrollend_targets\n                    .borrow_mut()\n                    .push(Dom::from_ref(target.as_ref()));\n            }\n            self.schedule_scrollend_event(can_gc);\n        }\n\n        // Step 4.\n        // > Run the steps to dispatch pending scrollsnapchange events for doc.\n        // TODO(#7673): Implement scroll snapping\n    }\n\n    /// Schedule a scrollend event to fire after a debounce delay.\n    /// This implements debouncing so that if multiple scrolls happen in quick succession,\n    /// only one scrollend event fires after the last scroll.\n    fn schedule_scrollend_event(&self, can_gc: CanGc) {\n        // Cancel any existing scrollend timer\n        if let Some(handle) = self.scrollend_timer.take() {\n            self.window().as_global_scope().unschedule_callback(handle);\n        }\n\n        // Schedule a new scrollend timer with a 150ms debounce delay\n        let callback = crate::timers::OneshotTimerCallback::ScrollendEvent(ScrollendCallback {\n            document: DomRoot::from_ref(self),\n        });\n        let duration = std::time::Duration::from_millis(150);\n        let handle = self.window()\n            .as_global_scope()\n            .schedule_callback(callback, duration);\n        self.scrollend_timer.set(Some(handle));\n    }\n\n    /// Fire pending scrollend events.\n    /// Called when the scrollend debounce timer fires.\n    pub(crate) fn fire_scrollend_events(&self, can_gc: CanGc) {\n        // Take all pending scrollend targets and fire scrollend for each\n        rooted_vec!(let targets <- self.pending_scrollend_targets.take().into_iter());\n        for target in targets.iter() {\n            if target.downcast::<Document>().is_some() {\n                // Scrollend on document bubbles\n                target.fire_bubbling_event(Atom::from(\"scrollend\"), can_gc);\n            } else if target.downcast::<Element>().is_some() {\n                // Scrollend on elements does not bubble\n                target.fire_event(Atom::from(\"scrollend\"), can_gc);\n            }\n        }\n    }",
