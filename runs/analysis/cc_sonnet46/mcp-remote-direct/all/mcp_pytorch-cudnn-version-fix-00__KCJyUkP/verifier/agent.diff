-    case ConvBackend::NnpackSpatial:
-    case ConvBackend::Slow2d:
-    case ConvBackend::SlowDilated2d:
-    case ConvBackend::SlowDilated3d:
-    case ConvBackend::SlowTranspose2d:
-    case ConvBackend::SlowTranspose3d:
