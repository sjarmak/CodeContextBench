# sg-gitlab-ratelimit-fix-001 — sg_only_env variant (v2: clone-at-verify)
# Source files truncated — agent uses Sourcegraph MCP for code access.
# Verifier clones mirror at verification time to restore source.

FROM golang:1.26-bookworm

ARG GITHUB_TOKEN

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates jq && \
    rm -rf /var/lib/apt/lists/*

# Allow /workspace ownership mismatch (agent runs as different user)
RUN git config --global --add safe.directory /workspace

# Clone repo and checkout pre-fix commit
RUN git init /workspace && cd /workspace && \
    git remote add origin https://x-access-token:${GITHUB_TOKEN}@github.com/sourcegraph/sourcegraph.git && \
    git fetch --depth=1 origin 531aad57d54123d359fa4262505f19b055341b3f && \
    git checkout FETCH_HEAD

ENV TASK_WORKDIR=/workspace
ENV TASK_REPO_ROOT=/workspace

WORKDIR /workspace

# Use Go module proxy; skip checksum for pseudo-version modules.
# Do NOT set GOPRIVATE — it bypasses the proxy and forces direct git access.
ENV GONOSUMCHECK=github.com/sourcegraph/*
ENV GOFLAGS=-mod=mod

# Pre-download Go dependencies for the relevant packages.
RUN go mod download -modcacherw 2>/dev/null || true

# Pre-build the test packages to cache compilation (ignore private dep errors)
RUN go build ./cmd/frontend/internal/auth/gitlaboauth/... 2>/dev/null || true && \
    go build ./internal/extsvc/gitlab/... 2>/dev/null || true

# Truncate source files so agent cannot read them locally.
RUN find /workspace -type f \( -name "*.go" -o -name "*.ts" -o -name "*.tsx" -o -name "*.js" -o -name "*.jsx" -o -name "*.py" -o -name "*.java" -o -name "*.rs" -o -name "*.rb" -o -name "*.c" -o -name "*.cc" -o -name "*.cpp" -o -name "*.h" -o -name "*.hpp" -o -name "*.md" -o -name "*.txt" -o -name "*.yaml" -o -name "*.yml" -o -name "*.toml" -o -name "*.json" -o -name "*.xml" -o -name "*.sh" -o -name "*.bash" -o -name "*.sql" -o -name "*.svelte" -o -name "*.vue" -o -name "*.css" -o -name "*.scss" -o -name "*.html" \) ! -path "*/.git/*" ! -path "*/node_modules/*" -exec truncate -s 0 {} \;
# Recommit truncated state so git history cannot recover full files.
RUN cd /workspace && git config user.email "agent@example.com" && \
    git config user.name "Agent" && \
    git add -A && git commit -m "sg_only truncation" --allow-empty --quiet

# Clone manifest for verifier (clone-at-verify strategy)
RUN echo '{"workdir":"/workspace","repos":[{"mirror":"sourcegraph/sourcegraph","commit":"531aad57d54123d359fa4262505f19b055341b3f","target_dir":"."}]}' > /tmp/.sg_only_clone_manifest.json

# Mark sg_only mode
RUN touch /tmp/.sg_only_mode && echo '/workspace' > /tmp/.sg_only_workdir

# Configure git auth so verifier can clone private repo at verify time
RUN echo "machine github.com login x-access-token password ${GITHUB_TOKEN}" > /root/.netrc && chmod 600 /root/.netrc

RUN mkdir -p /logs/agent /logs/verifier

# Pre-create claude user and set ownership at build time.
RUN (adduser --disabled-password --gecos '' claude 2>/dev/null || true) && \
    cp /root/.netrc /home/claude/.netrc && chown claude:claude /home/claude/.netrc && \
    for d in /workspace /app /testbed /logs; do [ -d "$d" ] && chown -R claude:claude "$d"; done || true

# Harness-agnostic: ensure all users (root/claude) can read+write workspace files
RUN chmod -R a+rwX /workspace

ENTRYPOINT []
