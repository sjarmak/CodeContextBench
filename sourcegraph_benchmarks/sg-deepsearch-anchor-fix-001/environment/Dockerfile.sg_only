# sg-deepsearch-anchor-fix-001 — sg_only_env variant (v3: no-clone)
# Source files NOT present — agent uses Sourcegraph MCP for code access.
# Verifier clones mirror at verification time to restore source.
#
# No build-time or runtime clone. Agent works with MCP only.
# Verifier uses clone manifest to restore repo before running tests.

FROM node:22-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates jq && \
    rm -rf /var/lib/apt/lists/*

# Install pnpm at the version required by the repo
RUN corepack enable && corepack prepare pnpm@10.13.1 --activate

ENV TASK_WORKDIR=/workspace
ENV TASK_REPO_ROOT=/workspace

WORKDIR /workspace

# Empty git repo so agent can commit work
RUN git init && \
    git config user.email "agent@example.com" && \
    git config user.name "Agent"

# Clone manifest for verifier (clone-at-verify strategy)
RUN echo '{"workdir":"/workspace","repos":[{"mirror":"sourcegraph/sourcegraph","commit":"43d72ff447ebaac8c134bcabf1c6d8a0b76694e4","target_dir":"."}]}' > /tmp/.sg_only_clone_manifest.json

# Mark sg_only mode
RUN touch /tmp/.sg_only_mode && echo '/workspace' > /tmp/.sg_only_workdir

RUN mkdir -p /logs/agent /logs/verifier

# Pre-create claude user and set ownership at build time.
RUN (adduser --disabled-password --gecos '' claude 2>/dev/null || true) && \
    for d in /workspace /logs; do chown -R claude:claude "$d"; done || true

# Harness-agnostic: ensure all users (root/claude) can read+write workspace files
RUN chmod -R a+rwX /workspace

ENTRYPOINT []
