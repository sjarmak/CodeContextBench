# Build and virtualenv
__pycache__/
*.pyc
*.pyo
.venv/

# All dotfiles/dotdirs (local tooling, IDE, CI, etc.)
.*
!.gitignore
!.gitattributes
# Repo CI (workflows live here; do not ignore)
!.github/
!.github/**

# Credentials and secrets
*.key
*.pem
*.env*
*.secret*
*credential*

# =============================================
# PUBLIC BRANCH: exclude development noise
# =============================================

# --- Docs: keep technical_reports and official_results ---
docs/*
!docs/technical_reports/
!docs/technical_reports/**
!docs/official_results/
!docs/official_results/**

# --- Runs: only keep snapshots (sanitized exports) ---
runs/
!runs/
runs/*
!runs/snapshots/
!runs/snapshots/**
# Block internal symlinked traces (only export/ is public)
runs/snapshots/*/traces/
runs/snapshots/*/summary/
# Allow export/ subdirectory through
!runs/snapshots/*/export/
!runs/snapshots/*/export/**

# --- Benchmarks: keep suites and indexes, block task definitions ---
benchmarks/*
!benchmarks/suites/
!benchmarks/suites/**
!benchmarks/indexes/
!benchmarks/indexes/**
!benchmarks/tasks/
benchmarks/tasks/*/
!benchmarks/README.md

# --- Internal development directories ---
calibration/
configs/
data/
eval_reports/
fixtures/
jobs/
logs/
ralph/
ralph-*/
reports/
results/
sourcegraph_benchmarks/
sourcegraph_tasks/
templates/
tmp/
releases/

# --- Large external datasets ---
ccb_crossrepo/
!benchmarks/ccb_crossrepo/
harbor-ccb_crossrepo-dataset/
vendor/DependEval/
vendor/dependeval_repos/

# --- Harbor integration (private) ---
ccb_harbor/

# --- Misc ---
archive/
oracle_curation_log.json
*.log
*.db
ds
browse/
